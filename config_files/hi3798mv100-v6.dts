// SPDX-License-Identifier: GPL-2.0
/*
 * Device Tree for HI3798MV100 board (e.g., EC6108V9C)
 * Fixed eMMC spamming and Ethernet
 */

/dts-v1/;
#include "hi3798mv100.dtsi"

/ {
	model = "Hisilicon HI3798MV100 STB";
	compatible = "hisilicon,hi3798mv100";

	chosen {
		stdout-path = "serial0:115200n8";
		bootargs = "console=ttyAMA0,115200 earlycon root=/dev/mmcblk0p9 rootfstype=ext4 rootwait rw";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x40000000>; /* 1GB */
	};

	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		linux,cma {
			compatible = "shared-dma-pool";
			reusable;
			size = <0x10000000>;
			alignment = <0x100000>;
			linux,cma-default;
		};
	};

	vcc_3v3: regulator-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc-3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};

	vcc_1v8: regulator-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "vcc-1v8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on;
	};
};

/* UARTs */
&uart0 { status = "okay"; };
&uart1 { status = "okay"; };
&uart2 { status = "okay"; };

/* GPIOs (all needed) */
&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };
&gpio2 { status = "okay"; };
&gpio3 { status = "okay"; };
&gpio4 { status = "okay"; };
&gpio5 { status = "okay"; };
&gpio6 { status = "okay"; };

/* Watchdog */
&wdt0 {
	status = "okay";
	timeout-sec = <60>;
};

/* I2C */
&i2c0 { status = "okay"; clock-frequency = <400000>; };
&i2c1 { status = "okay"; clock-frequency = <400000>; };
&i2c2 { status = "okay"; clock-frequency = <400000>; };

/* SPI */
&spi0 {
	status = "okay";
	num-cs = <2>;
	cs-gpios = <&gpio1 0 GPIO_ACTIVE_LOW>,
		   <&gpio1 1 GPIO_ACTIVE_LOW>;
};

/*
 * eMMC (mmc0) – CRITICAL FIXES
 * - Disable HS200 mode (unreliable on many boards)
 * - Use only HS-DDR and HS modes
 * - Add explicit tuning properties
 * - Keep bus-width = 8
 */
&mmc {
	status = "okay";
	bus-width = <8>;
	non-removable;
	cap-mmc-highspeed;
	cap-mmc-hw-reset;
	mmc-ddr-1_8v;
	/* HS200 is often unstable – disable it */
	/delete-property/ mmc-hs200-1_8v;
	max-frequency = <100000000>;
	vmmc-supply = <&vcc_3v3>;
	vqmmc-supply = <&vcc_1v8>;
	/* Add delay for power sequencing */
	mmc-pwrseq = <&mmc_pwrseq>;
	/* Optional: keep a slower initial frequency */
	/delete-property/ assigned-clocks;
	/delete-property/ assigned-clock-rates;
};

/*
 * SD card (mmc1) – if not used, disable it to avoid polling
 * If your board has no SD slot, set status = "disabled".
 * If it does have a slot, adjust cd-gpios.
 */
&sd {
	status = "disabled";   /* Change to "okay" if you have an SD slot */
	/*
	bus-width = <4>;
	cap-sd-highspeed;
	max-frequency = <100000000>;
	cd-gpios = <&gpio0 0 GPIO_ACTIVE_LOW>;
	vmmc-supply = <&vcc_3v3>;
	*/
};

/* Simple power sequence for eMMC (if needed) */
mmc_pwrseq: pwrseq {
	compatible = "mmc-pwrseq-simple";
	reset-gpios = <&gpio6 7 GPIO_ACTIVE_LOW>; /* placeholder – adjust or remove */
};

/*
 * Ethernet – use hisi-femac-v2 (mainline)
 * The PHY is usually at address 1 on the MDIO bus.
 * If your board uses an external PHY, ensure the reset GPIO is correct.
 */
&eth0 {
	status = "okay";
	phy-handle = <&phy1>;
	phy-mode = "mii";
	/* Reset delays – adjust if your PHY needs different values */
	hisilicon,phy-reset-delays-us = <10000 10000 20000>;
	/* If your PHY has a reset GPIO, add: */
	/* phy-reset-gpios = <&gpio5 2 GPIO_ACTIVE_LOW>; */
};

&mdio0 {
	status = "okay";

	phy1: ethernet-phy@1 {
		reg = <1>;
		/* The bootloader will fill the MAC address */
	};
};

/* Infrared */
&ir {
	status = "okay";
	linux,rc-map-name = "rc-hisi";
};

/* GPU */
&gpu {
	status = "okay";
	mali-supply = <&vddgpu>;
};

&vddgpu {
	regulator-min-microvolt = <900000>;
	regulator-max-microvolt = <1320000>;
	regulator-always-on;
};

/* NAND (disabled) */
&nand { status = "disabled"; };

/* USB PHYs – enable both */
&usb2_phy1 { status = "okay"; };
&usb2_phy2 { status = "okay"; };
&combphy0 { status = "disabled"; };
&combphy1 { status = "disabled"; };

/* USB host controllers – keep them enabled */
&ohci0 { status = "okay"; };
&ehci0 { status = "okay"; };
&xhci0 { status = "okay"; };
&ohci1 { status = "okay"; };
&ehci1 { status = "okay"; };

/* Timers – all sp804 timers, but we rely on the hisilicon timer */
&timer1 { status = "okay"; };
&timer2 { status = "okay"; };
&timer3 { status = "okay"; };
&timer4 { status = "okay"; };